# ARGILETTE SEO Analytics - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/your_crm_db
# Note: ARGILETTE uses the same database as your CRM

# ============================================================================
# AUTHENTICATION
# ============================================================================
SESSION_SECRET=your-secret-key-here
# Generate with: openssl rand -base64 32

# ============================================================================
# AI FEATURES (Required for AI insights)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
# Get your key at: https://console.anthropic.com/
# Used for:
# - AI-powered SEO insights
# - Automatic keyword recommendations
# - AI backlink generation (free alternative to DataForSEO)
# - Local SEO profile generation

# ============================================================================
# BACKLINK ANALYSIS (Optional - for API mode)
# ============================================================================
# DataForSEO credentials (optional, for real backlink data)
# Free AI mode works without these
DATAFORSEO_LOGIN=your_login@example.com
DATAFORSEO_PASSWORD=your_password_here
# Note: DataForSEO requires paid subscription (~$100/month)
# Default AI mode is free and works without these credentials

# ============================================================================
# STRIPE INTEGRATION (Optional - for subscriptions)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx
# Only needed if using Stripe for billing

# ============================================================================
# REPLIT AUTH (Optional - if using Replit Auth)
# ============================================================================
# ISSUER_URL is auto-configured by Replit
# If using your own auth, you can ignore this

# ============================================================================
# FRONTEND (Optional - for Vite frontend)
# ============================================================================
# Any VITE_ prefixed variables are exposed to frontend
VITE_APP_NAME=Your CRM SEO
VITE_API_URL=http://localhost:3000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features
ENABLE_LOCAL_SEO=true
ENABLE_SOCIAL_MEDIA=true
ENABLE_AI_INSIGHTS=true
ENABLE_API_ACCESS=true
ENABLE_AUTOMATED_REPORTS=true

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
API_RATE_LIMIT=1000
# Requests per hour per API key

# ============================================================================
# EMAIL (Optional - for reports)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=noreply@yourcrm.com

# ============================================================================
# DEVELOPMENT
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================================
# PRODUCTION (for deployment)
# ============================================================================
# NODE_ENV=production
# PORT=5000
# LOG_LEVEL=info
