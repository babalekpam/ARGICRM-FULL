# ─── DATABASE (required) ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname
SESSION_SECRET=your-64-char-session-secret-here
JWT_SECRET=your-64-char-jwt-secret-here

# ─── AI PROVIDERS ───────────────────────────────────────────────
# Add ANY one (or more) of the following. The system auto-detects
# and falls back through the list if one fails.
#
# Priority: Anthropic → OpenAI → Google → Groq → Mistral →
#           Cohere → Together → Fireworks → Perplexity → Ollama

# Option 1: Anthropic Claude (claude.ai)
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: OpenAI GPT-4 (platform.openai.com)
OPENAI_API_KEY=sk-...

# Option 3: Google Gemini (aistudio.google.com — free tier available)
GOOGLE_AI_KEY=AIza...

# Option 4: Groq — FASTEST, FREE TIER (console.groq.com)
# Uses Llama 3.3 70B — great quality, 30 req/min free
GROQ_API_KEY=gsk_...

# Option 5: Mistral (console.mistral.ai — free tier)
MISTRAL_API_KEY=...

# Option 6: Cohere (dashboard.cohere.com — free tier)
COHERE_API_KEY=...

# Option 7: Together AI (api.together.xyz — open source models)
TOGETHER_API_KEY=...

# Option 8: Fireworks AI (fireworks.ai)
FIREWORKS_API_KEY=...

# Option 9: Perplexity (perplexity.ai — great for research/web)
PERPLEXITY_API_KEY=pplx-...

# Option 10: Ollama — 100% local, zero cost (ollama.com)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Force a specific provider (optional, overrides auto-detection):
# AI_PROVIDER=groq

# ─── OPTIONAL INTEGRATIONS ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# GitHub token for higher API rate limits (optional, 60→5000 req/hr)
GITHUB_TOKEN=ghp_...

# Platform owner email
PLATFORM_OWNER_EMAIL=abel@argilette.com
PLATFORM_OWNER_PASSWORD=ArgiletteSecure2024!
